# Environment variables for local development
# Copy this file to .env and fill in your values

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Docker Settings
DOCKER_IMAGE=cloud-native-python-app
DOCKER_TAG=latest

# AWS Settings (for Terraform)
AWS_REGION=eu-central-1
AWS_PROFILE=default

# Terraform Variables
TF_VAR_project_name=cloud-native-python
TF_VAR_environment=dev
TF_VAR_instance_type=t3.medium

# Deployment Settings
SERVER_IP=your-ec2-ip-here
SSH_KEY_PATH=~/.ssh/cloud-native-key
